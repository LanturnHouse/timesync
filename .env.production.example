# ============================================================
# TimeSync — Production Environment Variables
# Copy this file to .env.production and fill in real values.
# DO NOT commit .env.production to git.
# ============================================================

# ---------- PostgreSQL ----------
POSTGRES_DB=timesync
POSTGRES_USER=timesync_user
POSTGRES_PASSWORD=CHANGE_ME_strong_password_here
POSTGRES_HOST=db
POSTGRES_PORT=5432

# ---------- Redis ----------
REDIS_URL=redis://redis:6379/0

# ---------- Django ----------
# Generate with: python -c "from django.core.management.utils import get_random_secret_key; print(get_random_secret_key())"
DJANGO_SECRET_KEY=CHANGE_ME_generate_a_random_50_char_key
DJANGO_DEBUG=False
DJANGO_SETTINGS_MODULE=config.settings.production
DJANGO_ALLOWED_HOSTS=timesync.lanturn.info,backend

# ---------- Google OAuth ----------
GOOGLE_OAUTH_CLIENT_ID=your-google-client-id.apps.googleusercontent.com
GOOGLE_OAUTH_CLIENT_SECRET=GOCSPX-your-secret-here

# ---------- Frontend ----------
NEXT_PUBLIC_API_URL=https://timesync.lanturn.info/api
NEXT_PUBLIC_GOOGLE_CLIENT_ID=your-google-client-id.apps.googleusercontent.com
FRONTEND_URL=https://timesync.lanturn.info

# ---------- Anthropic AI ----------
ANTHROPIC_API_KEY=sk-ant-api03-your-key-here

# ---------- Toss Payments ----------
TOSS_CLIENT_KEY=live_ck_your_live_client_key
TOSS_SECRET_KEY=live_sk_your_live_secret_key
NEXT_PUBLIC_TOSS_CLIENT_KEY=live_ck_your_live_client_key

# ---------- Email (SMTP) ----------
# Optional: leave blank to disable outbound email
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_HOST_USER=your@gmail.com
EMAIL_HOST_PASSWORD=your-gmail-app-password
DEFAULT_FROM_EMAIL=noreply@timesync.lanturn.info
